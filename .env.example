# mao-skill 环境变量配置
# 复制此文件为 .env 并填入你的 API Key

# ===== LLM 提供商 =====
# 可选: claude / openai / qwen
LLM_PROVIDER=claude

# Claude API (推荐)
# 获取: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API (可选)
# 获取: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ===== RAG 配置 =====
# 向量模型 (mxbai-embed-large 效果好且免费)
EMBEDDING_MODEL=mxbai-embed-large

# ===== TTS 配置 =====
# 可选: chat_tts / edge / cosyvoice
TTS_ENGINE=chat_tts

# ===== 数字人配置 =====
# Live2D 模型路径 (可选)
# LIVE2D_MODEL=mao_pro
# LIVE2D_PATH=models/mao_pro.model3.json